# Copy to .env and set values. Do not commit .env.

# Server
NODE_ENV=production
PORT=3000

# Admin key — protects /api/admin/* routes in production
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=

# Production: allowed origin for CORS (e.g. https://serenest.in). Leave empty to allow all.
ALLOWED_ORIGIN=

# Your live site base URL (used for Google OAuth redirect and post-login redirects)
APP_BASE_URL=https://serenest.in

# Cron secret (protect /api/cron/send-reminders)
CRON_SECRET=

# Telegram (for visit pings)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Twilio (shared for SMS OTP + WhatsApp notifications)
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# SMS number for OTP (e.g. +14155238886)
TWILIO_SMS_FROM=
# WhatsApp sender (e.g. whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=
# WhatsApp recipient for admin notifications (e.g. whatsapp:+919876543210)
TWILIO_WHATSAPP_TO=

# Resend (booking confirmation + reminder emails)
# Get from: https://resend.com
RESEND_API_KEY=
BOOKING_FROM_EMAIL=Serenest <bookings@serenest.in>
BOOKING_VIDEO_LINK=

# Google OAuth (for "Sign in with Google")
# Steps:
#  1. Go to https://console.cloud.google.com/apis/credentials
#  2. Create OAuth 2.0 Client ID → Web application
#  3. Add Authorised redirect URI: https://serenest.in/api/auth/google/callback
#  4. Copy Client ID and Client Secret here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://serenest.in/api/auth/google/callback
