# ============================================================
# Serenest — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Supabase (Frontend — public, safe to expose) ─────────────
# Get from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase (Server — secret, never expose to browser) ──────
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Daily.co (Server — secret, never expose to browser) ──────
# Get from: https://dashboard.daily.co/developers
DAILY_API_KEY=your-daily-api-key-here

# ── Admin API protection ──────────────────────────────────────
# A random secret string used to protect admin-only API routes.
# Generate one: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-long-random-string

# ── Server ───────────────────────────────────────────────────
PORT=3000

# ── CORS (optional — set to your production domain) ──────────
# CORS_ORIGIN=https://serenest.in

# ── OpenAI — Serenest Guide (server-only; never expose to browser) ──
# Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic — Academy & Social content generation (server-only) ──
# Used by /api/academy/content/generate and /api/social/generate (admin only).
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── Lead alerts — email via Resend ───────────────────────────
# WITHOUT THESE, NEW BOOKINGS/SCREENINGS DO NOT NOTIFY ANYONE —
# leads sit unseen in /admin. Get a free key (3000 emails/mo)
# at https://resend.com
RESEND_API_KEY=re-your-resend-key-here
NOTIFY_EMAIL=you@example.com
# NOTIFY_FROM=Serenest Alerts <onboarding@resend.dev>

# ── Lead alerts — team WhatsApp via CallMeBot (free) ─────────
# https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_WHATSAPP_APIKEY=your-callmebot-apikey
CALLMEBOT_WHATSAPP_PHONE=917777936367

# ── Lead alerts — Telegram backup (optional) ─────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Payments — Razorpay (optional) ───────────────────────────
# When both keys are set, bookings require payment up front and are
# confirmed instantly. Leave unset for manual "we'll call you" flow.
# Kill-switch: PAYMENTS_ENABLED=false disables payment even with keys set.
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
# RAZORPAY_KEY_SECRET=your-razorpay-secret
# PAYMENTS_ENABLED=true
# DEFAULT_FEE_INR=499

# ── Analytics — Google Analytics 4 (optional) ────────────────
# Set your GA4 measurement ID to enable analytics + conversion events
# (book_request_submitted, screening_completed). No ID = no tracking code.
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Frontend API base URL (optional) ─────────────────────────
# Leave empty for same-origin (production).
# Set to http://localhost:3000 if running frontend and backend separately.
# VITE_API_URL=

# ── WhatsApp channel / community link ────────────────────────
# Paste your WhatsApp Channel or Community invite link here.
# When you approve a professional in Admin → Applications, a "WA Welcome"
# button appears that opens WhatsApp with a pre-filled welcome message
# containing this link — one tap to send.
# Set this in Render → Environment → VITE_WA_CHANNEL_LINK
VITE_WA_CHANNEL_LINK=https://whatsapp.com/channel/your-channel-link-here

# Note: Serenest Academy is now part of the main app (served at /academy on
# the same deploy) — VITE_SERENEST_ACADEMY_URL / VITE_SERENEST_EDUCATION_URL
# are no longer needed and have been retired.
